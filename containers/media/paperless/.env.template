# Paperless-ngx Database
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# Paperless Admin
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=CHANGE_ME_admin_password

# Paperless App
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
PAPERLESS_SECRET_KEY=CHANGE_ME_generate_a_secret_key
PAPERLESS_URL=https://paperless.local
TZ=Europe/Amsterdam

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# ==============================================================================
# PAPERLESS SERVICE COMPANION ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Paperless-ngx Connectivity
# ------------------------------------------------------------------------------
# Set to 'http://paperless' if inside the same docker-compose stack.
# Set to your server's local LAN IP (e.g., http://192.168.1.10) if in a separate stack.
PAPERLESS_URL=http://paperless

# Set to 8000 for internal container networks, or 8010 if routing via your host machine.
PAPERLESS_PORT=8000

# Your Paperless-ngx REST API Token (Generated via Web UI -> Settings -> API Tokens).
API_SECRET_KEY=your_paperless_api_token_here

# ------------------------------------------------------------------------------
# 2. AI Inference Engine Settings (Ollama on Gaming PC)
# ------------------------------------------------------------------------------
AI_PROVIDER=ollama

# The local static network IPv4 address of your gaming PC. 
# DO NOT use 'localhost' or '127.0.0.1' (as that targets the Docker container itself).
OLLAMA_IP=192.168.1.123

# Default port used by Ollama. (Requires OLLAMA_HOST=0.0.0.0 environment variable on your PC).
OLLAMA_PORT=11434

# Text-optimized model pulled locally on your PC. Recommended: qwen2.5:7b-instruct
OLLAMA_MODEL=hf.co/unsloth/gemma-4-12b-it-GGUF:Q6_K
VISION_LLM_MODEL=deepseek-ocr:latest

# ------------------------------------------------------------------------------
# 3. Automation Overrides (For Intermittent Manual Workflows)
# ------------------------------------------------------------------------------
# Set to 0 to stop the container from checking for files automatically in the background.
SCAN_INTERVAL=0
USE_TAGS=true
