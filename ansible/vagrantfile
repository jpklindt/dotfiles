Vagrant.configure("2") do |config|
  config.vm.box = "nglgzz/fedora-server-44"

  config.vm.network "private_network", ip: "192.168.122.122"

  config.vm.provider :libvirt do |libvirt|
    libvirt.memory = 4096
    libvirt.cpus = 4
    
    libvirt.storage :file, :size => '50G'
    libvirt.storage :file, :size => '100G'
  end
    
  config.vm.provision "ansible" do |ansible|
    ansible.playbook = "playbook.yml"
    ansible.limit = "all"
    ansible.groups = {
      "homeservers" => ["default"]
    }
  end
config.vm.network "forwarded_port", guest: 2283, host: 2283
config.vm.network "forwarded_port", guest: 8080, host: 8080
end