[Unit]
Description=Nextcloud Server
Requires=nextcloud-database.container nextcloud-valkey.container
After=nextcloud-database.container nextcloud-valkey.container

[Container]
ContainerName=nextcloud-server
Pod=nextcloud.pod
Image=docker.io/nextcloud:{{ nextcloud_version }}
Volume={{ nextcloud_html_dir }}:/var/www/html:z
Volume={{ nextcloud_data_dir }}:/var/www/html/data:z
Volume={{ paperless_media_dir }}/documents/archive:/paperless_archive:z
Volume={{ paperless_consume_dir }}:/paperless_consume:z
Environment=POSTGRES_HOST=localhost
Environment=POSTGRES_DB={{ vault_nextcloud_db_name }}
Environment=POSTGRES_USER={{ vault_nextcloud_db_user }}
Environment=POSTGRES_PASSWORD={{ vault_nextcloud_db_password }}
Environment=REDIS_HOST=localhost
Environment=NEXTCLOUD_ADMIN_USER={{ vault_nextcloud_admin_user }}
Environment=NEXTCLOUD_ADMIN_PASSWORD={{ vault_nextcloud_admin_password }}
Environment="NEXTCLOUD_TRUSTED_DOMAINS={{ nextcloud_trusted_domains }}"
Environment=OVERWRITEPROTOCOL={{ nextcloud_overwrite_protocol }}
Environment=OVERWRITEHOST={{ nextcloud_domain }}
Environment=OVERWRITECLIURL={{ nextcloud_overwrite_protocol }}://{{ nextcloud_domain }}
Environment=TZ={{ nextcloud_timezone }}

[Service]
TimeoutStartSec=900